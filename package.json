{
  "name": "pokehaven-launcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "electron-vite build",
    "start": "node scripts/run-electron-vite.mjs preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "check:svelte": "svelte-check --tsconfig tsconfig.web.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/node": "^22.10.2",
    "electron": "^42.4.1",
    "electron-vite": "^5.0.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
